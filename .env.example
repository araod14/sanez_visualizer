# .env.example — copia a `.env` y ajusta. Todas las vars se mapean en app/config.py.
# Para arrancar local rápido basta con DEV_MODE + las credenciales del super-admin.

# ── Modo / sesión ────────────────────────────────────────────────────────────
# DEV_MODE=1 permite arrancar sin SECRET_KEY (genera una efímera) y desactiva el
# flag Secure de la cookie para poder usar HTTP local. NO usar en producción.
DEV_MODE=1
# Obligatoria en producción (DEV_MODE=0). Genera una con: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=
# Flag Secure de la cookie. Default: 1 fuera de DEV_MODE. Si prod NO está tras HTTPS, poné 0.
# SESSION_HTTPS_ONLY=1
# lax (default) / strict / none
# SESSION_SAME_SITE=lax

# ── Super-admin (bootstrap idempotente al arrancar) ──────────────────────────
SUPER_ADMIN_EMAIL=admin@local
SUPER_ADMIN_PASSWORD=admin

# ── Rate limit de login (en memoria por IP) ──────────────────────────────────
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_WINDOW_SECONDS=300

# ── Base de datos ────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///./sanez.db

# ── Scheduler BCV (scraper de tasas) ─────────────────────────────────────────
# SCHEDULER_ENABLED=1
# SCHEDULER_HOUR=14
# SCHEDULER_MINUTE=0
# SCHEDULER_TZ=America/Caracas

# ── Uploads ──────────────────────────────────────────────────────────────────
# UPLOAD_DIR=static/uploads
# UPLOAD_MAX_BYTES=5242880

# ── Generación de fondos por IA (texto → imagen) ─────────────────────────────
# Opción GRATIS y sin API key (ideal para pruebas): descomenta esta línea.
# IMAGE_PROVIDER=pollinations
#
# Opción Gemini (default): requiere IMAGE_API_KEY + billing habilitado en Google
# (los modelos de imagen tienen limit:0 en free tier). Sin la key, la UI muestra
# la opción pero generar devuelve un error de configuración.
# IMAGE_PROVIDER=gemini
# IMAGE_API_KEY=
# IMAGE_MODEL=gemini-2.5-flash-image
# IMAGE_ASPECT_RATIO=16:9
